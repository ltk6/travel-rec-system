# ─────────────────────────────────────────────────────────
# N8 — Environment Variables
# Copy file này thành .env và điền giá trị thực
# ─────────────────────────────────────────────────────────

# URL của N2 service (FastAPI chạy riêng bằng uvicorn)
# Mặc định: http://localhost:8001/api/v1/process-image
N2_SERVICE_URL=http://localhost:8001/api/v1/process-image

# Timeout khi gọi N2 (giây). Nếu N2 chậm hơn → tự động fallback
N2_TIMEOUT=10

# MongoDB connection string (dùng cho N3)
# Nếu không set → N3 tự dùng localhost:27017
MONGO_URI=mongodb://localhost:27017/
